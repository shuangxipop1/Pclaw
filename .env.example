# Pclaw Environment Variables
# Copy this file to .env on the server or use with docker-compose

# PostgreSQL
PG_PASSWORD=pclaw123
PG_DB=pclaw

# JWT
JWT_SECRET=claw-jwt-secret-change-in-production

# Node.js
NODE_ENV=production
PORT=3001

# API Configuration
API_HOST=0.0.0.0
API_PORT=3001

# Use host PG (for hybrid mode, not fully containerized)
USE_HOST_PG=false
