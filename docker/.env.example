# Pclaw 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Gateway 端口
OPENCLAW_PORT=19001

# 日志级别 (silent|fatal|error|warn|info|debug|trace)
OPENCLAW_LOG_LEVEL=info

# 数据目录
OPENCLAW_DATA_DIR=/data

# 通道配置 (根据需要启用)
# TELEGRAM_BOT_TOKEN=your_bot_token
# DISCORD_BOT_TOKEN=your_discord_token
# QQBot_WS_URL=ws://localhost:8080
