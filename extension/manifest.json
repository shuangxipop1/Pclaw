{
  "manifest_version": 3,
  "name": "Pclaw AI 助手",
  "version": "1.0.0",
  "description": "工程行业智能AI助手 - 海上风电、海洋工程、结构设计专家",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg"
    },
    "default_title": "Pclaw AI 助手"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
